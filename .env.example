# Mobile env template. Copy to .env.<environment> and fill in.
# Values are baked into the native build at compile time, so no secrets here —
# anything in this file ships inside the APK/IPA.

# ─── API ───────────────────────────────────────────────────────────────────
# Default API host, used only for the initial verify_tenant call.
# After that, the API returns a tenant-specific apiUrl that overrides this.
API_BASE_URL=https://api.tenants.sanchidev.in/

# ─── Tenant ────────────────────────────────────────────────────────────────
# Tenant identifier passed to /verify_tenant/{slug}. Must match the tenant's
# `domain` field in the backend. In Phase 4 this is set per build flavor
# (com.sanchi.isba uses TENANT_SLUG=isba.<env>, etc.); for now it's global.
#
# Note on hosts:
# - sanchidev.in returns apiUrl pointing at api.thub.sanchidev.in (resolves OK)
#   → use TENANT_SLUG=thub.sanchidev.i
# - sanchiconnect.com returns apiUrl pointing at api.thub.sncnt.in (NXDOMAIN today)
#   → use TENANT_SLUG=thub (kept in .env.staging/.env.production for when ready)
TENANT_SLUG=thub.sanchidev.i

# ─── Environment label ─────────────────────────────────────────────────────
# 'development' | 'staging' | 'production' — informational only, used for
# debug overlays and crash-report tagging.
APP_ENV=development
